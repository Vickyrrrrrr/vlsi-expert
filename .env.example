# Qwen-VLSI-SOTA-Sprint — Environment Configuration
# Copy this file to .env and fill in your values

# ═══════════════════════════════════════════════════════════════
#  INFRASTRUCTURE — Model Paths & Ports
# ═══════════════════════════════════════════════════════════════

# Model IDs on HuggingFace
TEACHER_MODEL=vxkyyy/vlsi-moe-ffn-merged-formal
STUDENT_MODEL=Qwen/Qwen2.5-Coder-14B-Instruct
DRAFT_MODEL=Qwen/Qwen2.5-Coder-1.5B-Instruct

# vLLM ports
VLSI_TEACHER_PORT=8000
VLSI_DRAFT_PORT=8001
VLSI_BRIDGE_PORT=8002

# API authentication
VLSI_API_KEY=agentic-vlsi-expert-secure

# HuggingFace token (for gated/private models)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ═══════════════════════════════════════════════════════════════
#  STORAGE — 5TB Scratch Disk
# ═══════════════════════════════════════════════════════════════

# Path to 5TB NVMe scratch disk (datasets + checkpoints)
VLSI_SCRATCH=/scratch

# ═══════════════════════════════════════════════════════════════
#  DISTILLATION — Training Hyperparameters
# ═══════════════════════════════════════════════════════════════

DISTILL_BATCH_SIZE=2
DISTILL_GRAD_ACCUM=16
DISTILL_LR=2e-5
DISTILL_KD_TEMP=4.0
DISTILL_KD_ALPHA=0.9

# GaLore memory-efficient training
GALORE_RANK=128
GALORE_UPDATE_PROJ_GAP=200

# ═══════════════════════════════════════════════════════════════
#  FACTORY — Generation Concurrency
# ═══════════════════════════════════════════════════════════════

CONCURRENT_GENERATORS=16

# ═══════════════════════════════════════════════════════════════
#  AgentIC INTEGRATION
# ═══════════════════════════════════════════════════════════════

# Point AgentIC to the Bridge API
LLM_BASE_URL=http://localhost:8002/v1
LLM_API_KEY=agentic-vlsi-expert-secure
LLM_MODEL=vlsi-expert

OPENLANE_ROOT=~/vlsi-expert
SKIP_OPENLANE=1

# ═══════════════════════════════════════════════════════════════
#  ROCm — AMD GPU
# ═══════════════════════════════════════════════════════════════

PYTORCH_ROCM_ARCH=gfx942
HIP_VISIBLE_DEVICES=0
HSA_OVERRIDE_GFX_VERSION=9.4.2

# ═══════════════════════════════════════════════════════════════
#  OPERATIONAL COMMANDS
# ═══════════════════════════════════════════════════════════════
#
#  1. Setup infrastructure:
#     ./setup.sh
#
#  2. Launch teacher (Terminal 1):
#     ./setup.sh --serve-teacher
#
#  3. Launch draft (Terminal 2):
#     ./setup.sh --serve-draft
#
#  4. Start generation + verification:
#     python factory.py
#
#  5. Start distillation:
#     python distill.py
#
#  6. Launch bridge dashboard:
#     python bridge.py
#
#  7. Hot-swap to student model:
#     curl -X POST http://localhost:8002/v1/swap \
#       -d '{"model": "student"}'
#
#  8. Check dashboard:
#     curl http://localhost:8002/v1/dashboard
