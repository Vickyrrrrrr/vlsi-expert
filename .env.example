# VLSI Expert — Environment Configuration
# Copy this file to .env and fill in your values

# ═══════════════════════════════════════════════════════════
#  LOCAL MACHINE CONFIG (Your laptop/WSL)
# ═══════════════════════════════════════════════════════════

# Point to your VPS where the model is running
LLM_BASE_URL=http://YOUR_VPS_IP:8000/v1
LLM_API_KEY=agentic-vlsi-expert-secure
LLM_MODEL=vlsi-expert

# AgentIC specific
OPENLANE_ROOT=~/vlsi-expert
SKIP_OPENLANE=1

# ═══════════════════════════════════════════════════════════
#  VPS SERVER CONFIG (On the AMD MI300X instance)
# ═══════════════════════════════════════════════════════════

# Server settings
VLSI_PORT=8000
VLSI_API_KEY=agentic-vlsi-expert-secure

# HuggingFace token (for downloading private/gated models)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ROCm / PyTorch
PYTORCH_ROCM_ARCH=gfx942
HIP_VISIBLE_DEVICES=0

# ═══════════════════════════════════════════════════════════
#  EXAMPLE: SSH Tunnel (more secure than public port)
# ═══════════════════════════════════════════════════════════
#
# Instead of exposing port 8000 publicly, use SSH tunnel:
#
#   ssh -N -L 8000:localhost:8000 -i ~/.ssh/id_ed25519 ubuntu@YOUR_VPS_IP
#
# Then on local machine set:
#   LLM_BASE_URL=http://localhost:8000/v1
#
# This encrypts all traffic and requires no firewall rules.
